{
  "name": "semillas-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:build": "storybook build",
    "test": "bun test src",
    "storybook:coverage": "node ../scripts/check-storybook-coverage.mjs",
    "storybook:categories": "node ../scripts/migrate-storybook-categories.mjs",
    "storybook:categories:write": "node ../scripts/migrate-storybook-categories.mjs --write",
    "storybook:determinism": "node ../scripts/check-storybook-determinism.mjs",
    "storybook:determinism:write": "node ../scripts/check-storybook-determinism.mjs --write",
    "storybook:tags": "node ../scripts/check-storybook-tags.mjs",
    "storybook:tags:write": "node ../scripts/check-storybook-tags.mjs --write",
    "storybook:architecture": "node ../scripts/check-storybook-architecture.mjs",
    "storybook:test": "vitest --config vitest.config.ts --run",
    "storybook:test:a11y": "vitest --config vitest.config.ts --run",
    "storybook:check": "bun run storybook:categories && bun run storybook:determinism && bun run storybook:tags && bun run storybook:architecture && bun run storybook:coverage && bun run storybook:build",
    "storybook:ci": "bun run storybook:check && bun run storybook:test",
    "ui:check": "node ../scripts/check-ui-ux-slop.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@supabase/supabase-js": "^2.110.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-table": "^8.21.3",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.4",
    "lucide-react": "^1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.81.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/router-plugin": "1.168.19",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "11.0.0",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser": "4.1.10",
    "@vitest/browser-playwright": "4.1.10",
    "msw": "^2.15.0",
    "msw-storybook-addon": "^2.0.7",
    "storybook": "^10.4.6",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "^4.1.10"
  }
}
