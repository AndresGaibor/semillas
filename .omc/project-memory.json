      "restore:storage": "bun run scripts/restore-storage.ts",
      "restore:verify": "bun run scripts/verify-backups.ts",
      "restore:verify:db": "bun run scripts/verify-db-backup.ts",
      "test:coverage": "bun run --cwd backend test:coverage && bun run --cwd frontend test:coverage",
      "test:e2e": "bun run --cwd backend test:e2e && bun run test:pwa:e2e",
      "test:pwa:e2e": "bunx playwright test tests/e2e/smoke.spec.ts tests/e2e/pwa-installability.spec.ts tests/e2e/pwa-offline.spec.ts tests/e2e/gamificacion-social.spec.ts",
      "test:accessibility:e2e": "bunx playwright test tests/e2e/accessibility.spec.ts",
      "db:migrate": "supabase db push --linked",
      "db:lint": "supabase db lint --linked --level warning",
      "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > backend/src/db/database.types.ts",
      "storybook": "bun run --cwd frontend storybook",
      "storybook:build": "bun run --cwd frontend build-storybook",
      "storybook:coverage": "bun run --cwd frontend storybook:coverage",
      "storybook:check": "bun run --cwd frontend storybook:check"
