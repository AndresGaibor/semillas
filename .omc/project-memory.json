      "check": "bun run --cwd backend typecheck && bun run --cwd frontend typecheck && bun run test && bun run test:e2e && bun run build",
      "test": "bun run test:backend && bun run test:frontend && bun run test:contrato",
      "test:backend": "bun run --cwd backend test",
      "test:frontend": "bun run --cwd frontend test",
