      "build:backend": "bun run --cwd backend build",
      "deploy:backend": "bun run --cwd backend deploy",
      "deploy:backend:staging": "bun run --cwd backend deploy --env staging",
      "deploy:backend:production": "bun run --cwd backend deploy --env production",
      "deploy:frontend:staging": "bun run build:frontend && bunx wrangler pages deploy frontend/dist --project-name ${CF_PAGES_PROJECT_NAME:-semillas} --branch staging",
