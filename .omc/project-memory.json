      "i18n:check": "bun run scripts/check-i18n.ts",
      "performance:bundle": "bun run scripts/check-bundle-budget.ts",
      "performance:assets": "bun run scripts/optimize-assets.ts",
      "performance:lighthouse": "bun run build:frontend && bunx lhci autorun --config=lighthouserc.json",
      "pwa:check": "bun run scripts/check-pwa-build.ts",
      "smoke": "bun run scripts/smoke.ts",
      "smoke:staging": "SMOKE_API_URL=${STAGING_API_URL:?Configura STAGING_API_URL} SMOKE_FRONTEND_URL=${STAGING_FRONTEND_URL:?Configura STAGING_FRONTEND_URL} bun run smoke",
      "smoke:production": "SMOKE_API_URL=${PRODUCTION_API_URL:?Configura PRODUCTION_API_URL} SMOKE_FRONTEND_URL=${PRODUCTION_FRONTEND_URL:?Configura PRODUCTION_FRONTEND_URL} bun run smoke",
