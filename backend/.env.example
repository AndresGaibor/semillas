# Ambiente
APP_ENV=production
CORS_ORIGIN=https://semillas.org

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
SUPABASE_PROJECT_REF=tu-project-ref
SUPABASE_DATABASE_URL=postgresql://usuario:contrasena@host:5432/postgres

# Bootstrap local opcional (nunca habilitar en producción)
ENABLE_DEV_ADMIN_SETUP=false
DEV_ADMIN_EMAIL=admin.local@example.com
DEV_ADMIN_PASSWORD=cambia-esta-clave-local
DEV_ADMIN_SETUP_TOKEN=cambia-este-token-local-largo
