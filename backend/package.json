{
  "name": "semillas-backend",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bun test \"src/**/*.e2e.test.ts\" --pass-with-no-tests",
    "typecheck": "tsc --noEmit",
    "gen:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF --schema public > src/db/database.types.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "latest",
    "@libsql/client": "^0.17.4",
    "@scalar/hono-api-reference": "^0.11.8",
    "@supabase/supabase-js": "latest",
    "drizzle-orm": "^0.45.2",
    "hono": "latest",
    "openapi3-ts": "^4.6.0",
    "postgres": "^3.4.9",
    "zod": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@types/bun": "^1.3.14",
    "@types/node": "latest",
    "drizzle-kit": "^0.31.10",
    "supabase": "latest",
    "typescript": "latest",
    "wrangler": "latest"
  }
}
