{
  "name": "semillas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:backend": "bun run --cwd backend dev",
    "build": "bun run --cwd frontend build && bun run --cwd backend build",
    "build:frontend": "bun run --cwd frontend build",
    "build:backend": "bun run --cwd backend build",
    "deploy:backend": "bun run --cwd backend deploy",
    "deploy:backend:staging": "bun run --cwd backend deploy --env staging",
    "preview:backend": "bun run --cwd backend dev --remote",
    "check": "bun run --cwd backend typecheck && bun run --cwd frontend typecheck && bun run test && bun run test:e2e && bun run build",
    "test": "bun run test:backend && bun run test:frontend && bun run test:contrato",
    "test:backend": "bun run --cwd backend test",
    "test:frontend": "bun run --cwd frontend test",
    "test:contrato": "bun test tests/contrato-publico.test.ts",
    "test:e2e": "bun run --cwd backend test:e2e",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase db push",
    "db:lint": "supabase db lint --level warning",
    "db:types": "supabase gen types typescript --local > backend/src/db/database.types.ts",
    "storybook": "bun run --cwd frontend storybook",
    "storybook:build": "bun run --cwd frontend build-storybook",
    "storybook:coverage": "bun run --cwd frontend storybook:coverage",
    "storybook:check": "bun run --cwd frontend storybook:check"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "playwright": "^1.61.1"
  }
}
