{
  "name": "semillas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:backend": "bun run --cwd backend dev",
    "build": "bun run --cwd frontend build && bun run --cwd backend build",
    "build:frontend": "bun run --cwd frontend build",
    "build:backend": "bun run --cwd backend build",
    "deploy:backend": "bun run --cwd backend deploy",
    "deploy:backend:staging": "bun run --cwd backend deploy --env staging",
    "deploy:backend:production": "bun run --cwd backend deploy --env production",
    "deploy:frontend:staging": "bun run build:frontend && bunx wrangler pages deploy frontend/dist --project-name ${CF_PAGES_PROJECT_NAME:-semillas} --branch staging",
    "deploy:frontend:production": "bun run build:frontend && bunx wrangler pages deploy frontend/dist --project-name ${CF_PAGES_PROJECT_NAME:-semillas}",
    "deploy:frontend:artifact": "bunx wrangler pages deploy frontend/dist --project-name ${CF_PAGES_PROJECT_NAME:-semillas}",
    "deploy:frontend:artifact:staging": "bunx wrangler pages deploy frontend/dist --project-name ${CF_PAGES_PROJECT_NAME:-semillas} --branch staging",
    "preview:backend": "bun run --cwd backend dev --remote",
    "check": "bun run --cwd backend typecheck && bun run --cwd frontend typecheck && bun run test && bun run test:e2e && bun run build",
    "test": "bun run test:backend && bun run test:frontend && bun run test:contrato",
    "test:backend": "bun run --cwd backend test",
    "test:frontend": "bun run --cwd frontend test",
    "test:contrato": "bun test tests/contrato-publico.test.ts",
    "test:seguridad": "bun test tests/seguridad-configuracion.test.ts",
    "test:trazabilidad": "bun test tests/trazabilidad-requisitos.test.ts",
    "trazabilidad:check": "bun run scripts/validar-trazabilidad.ts",
    "docs:check": "bun run scripts/check-doc-links.ts",
    "docs:freshness": "bun run scripts/check-doc-freshness.ts",
    "i18n:check": "bun run scripts/check-i18n.ts",
    "performance:bundle": "bun run scripts/check-bundle-budget.ts",
    "performance:assets": "bun run scripts/optimize-assets.ts",
    "performance:lighthouse": "bun run build:frontend && bunx lhci autorun --config=lighthouserc.json",
    "pwa:check": "bun run scripts/check-pwa-build.ts",
    "smoke": "bun run scripts/smoke.ts",
    "smoke:staging": "SMOKE_API_URL=${STAGING_API_URL:?Configura STAGING_API_URL} SMOKE_FRONTEND_URL=${STAGING_FRONTEND_URL:?Configura STAGING_FRONTEND_URL} bun run smoke",
    "smoke:production": "SMOKE_API_URL=${PRODUCTION_API_URL:?Configura PRODUCTION_API_URL} SMOKE_FRONTEND_URL=${PRODUCTION_FRONTEND_URL:?Configura PRODUCTION_FRONTEND_URL} bun run smoke",
    "backup:db": "bun run scripts/backup-supabase.ts",
    "restore:db": "bun run scripts/restore-supabase.ts",
    "backup:storage": "bun run scripts/backup-storage.ts",
    "restore:storage": "bun run scripts/restore-storage.ts",
    "restore:verify": "bun run scripts/verify-backups.ts",
    "restore:verify:db": "bun run scripts/verify-db-backup.ts",
    "test:coverage": "bun run --cwd backend test:coverage && bun run --cwd frontend test:coverage",
    "test:e2e": "bun run --cwd backend test:e2e && bun run test:pwa:e2e",
    "test:pwa:e2e": "bunx playwright test tests/e2e/smoke.spec.ts tests/e2e/pwa-installability.spec.ts tests/e2e/pwa-offline.spec.ts tests/e2e/gamificacion-social.spec.ts",
    "test:accessibility:e2e": "bunx playwright test tests/e2e/accessibility.spec.ts",
    "db:migrate": "supabase db push --linked",
    "db:lint": "supabase db lint --linked --level warning",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > backend/src/db/database.types.ts",
    "storybook": "bun run --cwd frontend storybook",
    "storybook:build": "bun run --cwd frontend build-storybook",
    "storybook:coverage": "bun run --cwd frontend storybook:coverage",
    "storybook:check": "bun run --cwd frontend storybook:check"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3"
  }
}
